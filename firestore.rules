rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper functions
    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }
    
    function isValidComment(data) {
      return hasOnlyAllowedFields(['name', 'text', 'createdAt']) &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 50 &&
             data.text is string && data.text.size() > 0 && data.text.size() <= 500 &&
             data.createdAt is timestamp;
    }

    match /comments/{commentId} {
      // Allow anyone to read comments
      allow read: if true;
      
      // Allow anyone to create a comment if it's valid
      allow create: if isValidComment(request.resource.data) && 
                    request.resource.data.createdAt == request.time;
                    
      // Allow admin to delete comments
      allow delete: if isAuthenticated();
      allow update: if false;
    }

    // Projects collection
    match /projects/{projectId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    // Certificates collection
    match /certificates/{certificateId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    // Settings collection (for profile)
    match /settings/{document=**} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    // Announcements collection
    match /announcements/{announcementId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    // Gallery collection
    match /gallery/{galleryId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    // Playlist collection
    match /playlist/{songId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    // Skills collection
    match /skills/{skillId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    // Socials collection
    match /socials/{socialId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    // Testimonials collection
    match /testimonials/{testimonialId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }
  }
}
