{
  "entities": {
    "Project": {
      "title": "Project",
      "description": "A portfolio project.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "url": { "type": "string" },
        "description": { "type": "string" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "image": { "type": "string" },
        "createdAt": { "type": "timestamp" }
      },
      "required": ["name", "description", "createdAt"]
    },
    "Certificate": {
      "title": "Certificate",
      "description": "A certificate or achievement.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "tag": { "type": "string" },
        "url": { "type": "string" },
        "createdAt": { "type": "timestamp" }
      },
      "required": ["name", "url", "createdAt"]
    },
    "Profile": {
      "title": "Profile",
      "description": "Global profile information.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "nickname": { "type": "string" },
        "location": { "type": "string" },
        "email": { "type": "string" },
        "whatsapp": { "type": "string" },
        "summary": { "type": "string" },
        "status": { "type": "string" },
        "profileImage": { "type": "string" },
        "roles": { "type": "array", "items": { "type": "string" } },
        "mapsEmbed": { "type": "string" }
      },
      "required": ["name", "email"]
    },
    "Skill": {
      "title": "Skill",
      "description": "A skill category and its items.",
      "type": "object",
      "properties": {
        "category": { "type": "string" },
        "items": { "type": "array", "items": { "type": "string" } },
        "type": { "type": "string", "enum": ["programming", "other"] },
        "createdAt": { "type": "timestamp" }
      },
      "required": ["category", "items", "type", "createdAt"]
    },
    "Social": {
      "title": "Social",
      "description": "A social media link.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "handle": { "type": "string" },
        "url": { "type": "string" },
        "createdAt": { "type": "timestamp" }
      },
      "required": ["name", "handle", "url", "createdAt"]
    },
    "Testimonial": {
      "title": "Testimonial",
      "description": "A user testimonial.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "role": { "type": "string" },
        "text": { "type": "string" },
        "image": { "type": "string" },
        "createdAt": { "type": "timestamp" }
      },
      "required": ["name", "role", "text", "createdAt"]
    },
    "Comment": {
      "title": "Comment",
      "description": "A user comment.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "text": { "type": "string" },
        "createdAt": { "type": "timestamp" }
      },
      "required": ["name", "text", "createdAt"]
    },
    "Announcement": {
      "title": "Announcement",
      "description": "News or announcements with expiration.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "content": { "type": "string" },
        "expiresAt": { "type": "timestamp" },
        "createdAt": { "type": "timestamp" }
      },
      "required": ["title", "content", "expiresAt", "createdAt"]
    },
    "Gallery": {
      "title": "Gallery",
      "description": "Image gallery.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "imageUrl": { "type": "string" },
        "createdAt": { "type": "timestamp" }
      },
      "required": ["title", "imageUrl", "createdAt"]
    },
    "Playlist": {
      "title": "Playlist",
      "description": "Background music playlist.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "artist": { "type": "string" },
        "audioUrl": { "type": "string" },
        "createdAt": { "type": "timestamp" }
      },
      "required": ["title", "audioUrl", "createdAt"]
    }
  },
  "firestore": {
    "/projects/{projectId}": {
      "schema": { "$ref": "#/entities/Project" },
      "description": "Stores portfolio projects."
    },
    "/certificates/{certificateId}": {
      "schema": { "$ref": "#/entities/Certificate" },
      "description": "Stores certificates."
    },
    "/settings/profile": {
      "schema": { "$ref": "#/entities/Profile" },
      "description": "Stores global profile settings."
    },
    "/skills/{skillId}": {
      "schema": { "$ref": "#/entities/Skill" },
      "description": "Stores skills."
    },
    "/socials/{socialId}": {
      "schema": { "$ref": "#/entities/Social" },
      "description": "Stores social links."
    },
    "/testimonials/{testimonialId}": {
      "schema": { "$ref": "#/entities/Testimonial" },
      "description": "Stores testimonials."
    },
    "/comments/{commentId}": {
      "schema": { "$ref": "#/entities/Comment" },
      "description": "Stores user comments."
    },
    "/announcements/{announcementId}": {
      "schema": { "$ref": "#/entities/Announcement" },
      "description": "Stores announcements."
    },
    "/gallery/{galleryId}": {
      "schema": { "$ref": "#/entities/Gallery" },
      "description": "Stores gallery images."
    },
    "/playlist/{songId}": {
      "schema": { "$ref": "#/entities/Playlist" },
      "description": "Stores background music."
    }
  }
}
