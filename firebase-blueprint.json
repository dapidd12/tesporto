{
  "entities": {
    "Comment": {
      "title": "Comment",
      "description": "A comment left by a visitor on the portfolio.",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "The name of the visitor."
        },
        "text": {
          "type": "string",
          "description": "The content of the comment."
        },
        "createdAt": {
          "type": "timestamp",
          "description": "The time the comment was created."
        }
      },
      "required": ["name", "text", "createdAt"]
    }
  },
  "firestore": {
    "/comments/{commentId}": {
      "schema": {
        "$ref": "#/entities/Comment"
      },
      "description": "Stores all visitor comments."
    }
  }
}
